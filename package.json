{
  "name": "@aireon/shared",
  "version": "1.14.8",
  "description": "Shared UI components and utilities for the aireon app suite.",
  "type": "module",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/mbuchi/aireon-shared.git"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "default": "./dist/api/index.js"
    },
    "./signal-collect": {
      "types": "./dist/signal/handler.d.ts",
      "default": "./dist/signal/handler.js"
    },
    "./errorlog-collect": {
      "types": "./dist/errorlog/handler.d.ts",
      "default": "./dist/errorlog/handler.js"
    },
    "./gemini": {
      "types": "./dist/gemini/index.d.ts",
      "default": "./dist/gemini/index.js"
    },
    "./geoadmin": {
      "types": "./dist/geoadmin/index.d.ts",
      "default": "./dist/geoadmin/index.js"
    },
    "./map-interaction": {
      "types": "./dist/map/parcelInteraction.d.ts",
      "default": "./dist/map/parcelInteraction.js"
    },
    "./map-style": {
      "types": "./dist/map/maplibreStyle.d.ts",
      "default": "./dist/map/maplibreStyle.js"
    },
    "./basemap": {
      "types": "./dist/basemap/index.d.ts",
      "default": "./dist/basemap/index.js"
    },
    "./assets/brand/*": "./dist/assets/brand/*",
    "./map-ui.css": "./src/map/mapUi.css",
    "./basemap.css": "./src/basemap/basemap.css",
    "./cesium-app": "./src/cesium-app/index.js",
    "./cesium-app/*": "./src/cesium-app/*"
  },
  "files": [
    "dist",
    "src/map/mapUi.css",
    "src/cesium-app",
    "src/basemap/basemap.css"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "generate:api": "openapi-typescript ./openapi.json -o src/api/schema.ts",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@openreplay/tracker": ">=16",
    "lucide-react": ">=0.300.0",
    "maplibre-gl": ">=5",
    "oidc-client-ts": ">=3",
    "react": ">=18",
    "react-compiler-runtime": ">=1",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "@openreplay/tracker": {
      "optional": true
    },
    "maplibre-gl": {
      "optional": true
    }
  },
  "devDependencies": {
    "@openreplay/tracker": "^18.0.10",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "lucide-react": "^0.344.0",
    "maplibre-gl": "^5.24.0",
    "oidc-client-ts": "^3.5.0",
    "openapi-typescript": "^7.13.0",
    "react": "^18.3.1",
    "react-compiler-runtime": "^1.0.0",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.5.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.2",
    "openapi-fetch": "^0.13.8"
  }
}
